# ========================================
# SOLVEX AI — Environment Variables
# Copy this to .env.local and fill in values
# ========================================

# --- Supabase (Authentication + Database) ---
# Get these from: https://supabase.com → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- Anthropic (AI Brain) ---
# Get this from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Razorpay (Payments) ---
# Get these from: https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_live_your-key-id
RAZORPAY_KEY_SECRET=your-razorpay-secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_your-key-id

# --- App Config ---
NEXT_PUBLIC_APP_URL=https://your-domain.com
NEXT_PUBLIC_APP_NAME=Solvex AI

# --- Plans Config (in paise — 1 INR = 100 paise) ---
# Pro = ₹499/month
NEXT_PUBLIC_PRO_PRICE_INR=499
PRO_PRICE_PAISE=49900
